// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - username: string (required) - Unique handle
//   - displayName: string (optional) - User's name
//   - photoURL: string (optional) - Profile picture URL
//   - bio: string (optional) - User biography
//   - location: string (optional) - User location
//   - createdAt: number (required) - Creation timestamp
//   - isOnline: boolean (optional) - Online status
//   - lastSeen: number (optional) - Last seen timestamp
//   - role: string (required, enum: ["user", "admin", "moderator"]) - User role
//   - isSuspended: boolean (optional) - Suspension status
//
// Collection: groups
// Document ID: {groupId}
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - handle: string (optional)
//   - description: string (optional)
//   - type: string (required, enum: ["public", "private", "supergroup", "broadcast"])
//   - adminIds: array<string> (required)
//   - memberIds: array<string> (required)
//   - createdAt: number (required)
//   - createdBy: string (optional)
//   - photoURL: string (optional)
//
// Collection: messages
// Document ID: {messageId}
// Fields:
//   - id: string (required)
//   - chatId: string (required)
//   - senderId: string (required)
//   - senderName: string (required)
//   - content: string (required)
//   - timestamp: number (required)
//   - type: string (required, enum: ["text", "image", "system", "file", "voice"])
//   - imageUrl: string (optional)
//   - fileUrl: string (optional)
//   - fileName: string (optional)
//   - replyTo: string (optional)
//
// [Other collections follow similar patterns based on firebase-blueprint.json]
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "kvinit6421@gmail.com" && request.auth.token.email_verified == true));
    }

    function isModerator() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator' || isAdmin());
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isUnchanged(field) {
      return !(field in resource.data) || request.resource.data[field] == resource.data[field];
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidOptionalString(field, min, max) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= min && 
              request.resource.data[field].size() <= max);
    }

    function isValidUrl(field) {
      let url = request.resource.data[field];
      return url is string && url.size() <= 2048 && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidOptionalUrl(field) {
      return !(field in request.resource.data) || isValidUrl(field);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isTimestamp(field) {
      return request.resource.data[field] is timestamp;
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'username', 'createdAt', 'role']) &&
             hasOnlyAllowedFields(['uid', 'username', 'displayName', 'photoURL', 'bio', 'location', 'createdAt', 'isOnline', 'lastSeen', 'role', 'isSuspended']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.username.matches("^[a-zA-Z0-9_@]+$") &&
             isValidOptionalString('displayName', 1, 50) &&
             isValidOptionalUrl('photoURL') &&
             isValidOptionalString('bio', 0, 500) &&
             isValidOptionalString('location', 0, 100) &&
             (data.createdAt is timestamp || data.createdAt is number) &&
             isUnchanged('createdAt') &&
             isUnchanged('uid') &&
             data.role in ['user', 'admin', 'moderator'] &&
             (data.role == 'user' || isAdmin()); // Only admins can set admin/moderator roles
    }

    function isValidGroup(data) {
      return hasRequiredFields(['id', 'name', 'type', 'adminIds', 'memberIds', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'handle', 'description', 'type', 'adminIds', 'memberIds', 'bannedUserIds', 'createdAt', 'createdBy', 'photoURL', 'pinnedMessageId', 'slowMode', 'lastMessage', 'updatedAt']) &&
             data.id is string &&
             isUnchanged('id') &&
             isUnchanged('createdAt') &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 50 &&
             isValidOptionalString('handle', 3, 30) &&
             isValidOptionalString('description', 0, 1000) &&
             data.type in ['public', 'private', 'supergroup', 'broadcast'] &&
             data.adminIds is list && data.adminIds.size() > 0 &&
             data.memberIds is list && data.memberIds.size() > 0 &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidChannel(data) {
      return hasRequiredFields(['id', 'name', 'type', 'adminIds', 'subscriberIds', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'handle', 'description', 'type', 'adminIds', 'subscriberIds', 'createdAt', 'createdBy', 'photoURL', 'viewCount']) &&
             data.id is string &&
             isUnchanged('id') &&
             isUnchanged('createdAt') &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 50 &&
             isValidOptionalString('handle', 3, 30) &&
             isValidOptionalString('description', 0, 1000) &&
             data.type in ['public', 'private'] &&
             data.adminIds is list && data.adminIds.size() > 0 &&
             data.subscriberIds is list &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidMessage(data) {
      return hasRequiredFields(['id', 'chatId', 'senderId', 'content', 'timestamp', 'type']) &&
             hasOnlyAllowedFields(['id', 'chatId', 'senderId', 'senderName', 'content', 'timestamp', 'type', 'imageUrl', 'fileUrl', 'fileName', 'replyTo', 'status']) &&
             data.senderId == request.auth.uid &&
             isUnchanged('id') &&
             isUnchanged('chatId') &&
             isUnchanged('senderId') &&
             isUnchanged('timestamp') &&
             data.content is string && data.content.size() <= 5000 &&
             data.type in ['text', 'image', 'system', 'file', 'voice'] &&
             isValidOptionalUrl('imageUrl') &&
             isValidOptionalUrl('fileUrl') &&
             isValidOptionalString('fileName', 1, 255) &&
             (data.timestamp is timestamp || data.timestamp is number);
    }

    function isValidConversation(data) {
      return hasRequiredFields(['id', 'participantIds', 'updatedAt']) &&
             hasOnlyAllowedFields(['id', 'participantIds', 'lastMessage', 'lastMessageTimestamp', 'unreadCounts', 'updatedAt']) &&
             data.participantIds is list && data.participantIds.size() == 2 &&
             request.auth.uid in data.participantIds &&
             isUnchanged('id') &&
             isUnchanged('participantIds') &&
             (data.updatedAt is timestamp || data.updatedAt is number);
    }

    function isValidStory(data) {
      return hasRequiredFields(['id', 'userId', 'mediaUrl', 'type', 'createdAt', 'expiresAt']) &&
             hasOnlyAllowedFields(['id', 'userId', 'mediaUrl', 'type', 'createdAt', 'expiresAt', 'viewers']) &&
             data.userId == request.auth.uid &&
             isUnchanged('id') &&
             isUnchanged('userId') &&
             isUnchanged('createdAt') &&
             isValidUrl('mediaUrl') &&
             data.type in ['image', 'video'] &&
             (data.createdAt is timestamp || data.createdAt is number) &&
             (data.expiresAt is timestamp || data.expiresAt is number);
    }

    function isValidPost(data) {
      return hasRequiredFields(['id', 'userId', 'content', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'userId', 'content', 'mediaUrls', 'createdAt', 'likes']) &&
             data.userId == request.auth.uid &&
             isUnchanged('id') &&
             isUnchanged('userId') &&
             isUnchanged('createdAt') &&
             data.content is string && data.content.size() <= 10000 &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidHelpTicket(data) {
      return hasRequiredFields(['id', 'userId', 'title', 'category', 'description', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'userId', 'title', 'category', 'description', 'status', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             isUnchanged('id') &&
             isUnchanged('userId') &&
             isUnchanged('createdAt') &&
             data.title is string && data.title.size() >= 5 && data.title.size() <= 100 &&
             data.category in ["login", "chat", "payment", "report", "account", "other"] &&
             data.description is string && data.description.size() >= 10 && data.description.size() <= 2000 &&
             data.status in ["open", "pending", "resolved"] &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidReport(data) {
      return hasRequiredFields(['id', 'reporterId', 'targetId', 'reason', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'reporterId', 'targetId', 'reason', 'details', 'status', 'createdAt']) &&
             data.reporterId == request.auth.uid &&
             isUnchanged('id') &&
             isUnchanged('reporterId') &&
             isUnchanged('targetId') &&
             isUnchanged('createdAt') &&
             data.reason in ["spam", "abuse", "impersonation", "scam", "inappropriate", "other"] &&
             isValidOptionalString('details', 0, 1000) &&
             data.status in ["pending", "reviewed", "action_taken"] &&
             (data.createdAt is timestamp || data.createdAt is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Usernames collection (for unique usernames)
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.role == resource.data.role; // Cannot change own role
      allow update: if isAdmin();
    }

    // Groups collection
    match /groups/{groupId} {
      function isGroupAdmin() {
        return isAuthenticated() && (request.auth.uid in resource.data.adminIds || isAdmin());
      }
      function isGroupMember() {
        return isAuthenticated() && (request.auth.uid in resource.data.memberIds);
      }
      function isBanned() {
        return isAuthenticated() && ('bannedUserIds' in resource.data && request.auth.uid in resource.data.bannedUserIds);
      }

      allow read: if isAuthenticated() && !isBanned();
      allow create: if isAuthenticated() && isValidGroup(request.resource.data);
      allow update: if isAuthenticated() && !isBanned() && isValidGroup(request.resource.data) && (
        // Admin can do anything
        isGroupAdmin() ||
        // Users can join/leave
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
          // Cannot add others, only self
          (request.resource.data.memberIds.size() > resource.data.memberIds.size() ? 
            request.resource.data.memberIds.hasAll(resource.data.memberIds.concat([request.auth.uid])) :
            resource.data.memberIds.hasAll(request.resource.data.memberIds.concat([request.auth.uid])))
        )
      );
      allow delete: if isGroupAdmin();
    }

    // Channels collection
    match /channels/{channelId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChannel(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.adminIds || isAdmin()) && isValidChannel(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid in resource.data.adminIds || isAdmin());
    }

    // Messages collection
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin()) && isValidMessage(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    // Conversations collection
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participantIds || isAdmin());
      allow create: if isAuthenticated() && isValidConversation(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participantIds || isAdmin()) && isValidConversation(request.resource.data);
      allow delete: if isAdmin();
    }

    // Stories collection
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStory(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidPost(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Help Tickets
    match /help_tickets/{ticketId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isModerator());
      allow create: if isAuthenticated() && isValidHelpTicket(request.resource.data);
      allow update: if isModerator() && isValidHelpTicket(request.resource.data);
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isModerator() && isValidReport(request.resource.data);
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
